# DFS (Depth First Search)
graph = {
    "A": ["B", "C"],
    "B": ["D"],
    "C": ["D"],
    "D": []
}
def dfs (graph, node, visited=None):
    if visited is None:
        visited = set()

    if node not in visited:
        print(node, end="")
        visited.add(node)

        for nighbor in graph[node]:
            dfs(graph, nighbor, visited)

print("\nHasil DFS: ")
dfs(graph, "A")
